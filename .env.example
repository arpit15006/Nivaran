# ============================================================================
#  Nivaran — environment configuration
#  This is the ONE file you edit. Add your Groq key below; the rest have
#  working local defaults (matching docker-compose.yml).
# ============================================================================

# ---- LLM classifier (Groq) -------------------------------------------------
# Get a free key at https://console.groq.com/keys and paste it here.
GROQ_API_KEY=
# Model used for text/vision classification. See https://console.groq.com/docs/models
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Database (PostgreSQL) -------------------------------------------------
# Local default matches docker-compose. For prod use a managed pooled URL.
DATABASE_URL=postgresql://nivaran:nivaran@localhost:5432/nivaran?schema=public

# ---- Redis (BullMQ jobs, rate limits, cache) -------------------------------
REDIS_URL=redis://localhost:6379

# ---- Auth ------------------------------------------------------------------
# CHANGE THESE in any non-local environment. Use long random strings.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# ---- Server ----------------------------------------------------------------
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed frontend origins (CORS).
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
# Public base URL the browser uses to reach this API (used by the frontend).
NEXT_PUBLIC_API_BASE=http://localhost:4000/api/v1

# ---- Media storage (Cloudinary) -------------------------------------------
# Authenticated (private) uploads; DB stores public_id; signed delivery URLs.
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=
CLOUDINARY_FOLDER=nivaran

# ---- Media retention (privacy / DPDP) --------------------------------------
MEDIA_RETENTION_DAYS=30
